# NODASS API 配置
# 從 https://nodass.namr.gov.tw 申請 API 密鑰後，將其複製到此處
NAMR_API_KEY=your_api_key_here

# CWA API 配置
# 來自中央氣象署開放資料平台的授權碼
CWA_AUTHORIZATION=CWA-AE98C5BB-7FAB-482C-9BBE-199E11D2B2EB

# 資料源切換：nodass 或 cwa
DATA_SOURCE=nodass

# CWA 測站代碼（逗號分隔）
CWA_STATION_IDS=STATION_A,STATION_B,STATION_C

# 可選：自定義配置
# 數據爬取間隔（小時）
FETCH_INTERVAL_HOURS=2

# 爬取的天數範圍
FETCH_DAYS_RANGE=2
